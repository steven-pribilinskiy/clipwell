<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Clipwell.Ui"
        x:Class="Clipwell.Ui.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Clipwell"
        Width="560" Height="640"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">

    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            CornerRadius="10" Margin="8" BoxShadow="0 8 24 0 #40000000">
        <Grid Margin="14" RowDefinitions="Auto,Auto,*,Auto">

            <!-- Search -->
            <TextBox Grid.Row="0"
                     Name="SearchBox"
                     Text="{Binding SearchText, Mode=TwoWay}"
                     PlaceholderText="Search clipboard history…"
                     FontSize="15" CornerRadius="8" Padding="10,8" />

            <!-- Filter tabs + type dropdown -->
            <Grid Grid.Row="1" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Content="All" Command="{Binding SetFilterCommand}" CommandParameter="All"
                            Padding="12,4" CornerRadius="6" />
                    <Button Content="📌 Pinned" Command="{Binding SetFilterCommand}" CommandParameter="Pinned"
                            Padding="12,4" CornerRadius="6" />
                    <Button Content="🔒 Sensitive" Command="{Binding SetFilterCommand}" CommandParameter="Sensitive"
                            Padding="12,4" CornerRadius="6" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Content="{Binding ViewToggleLabel}" Command="{Binding ToggleViewCommand}"
                            Padding="10,4" CornerRadius="6" />
                    <ComboBox MinWidth="120"
                              ItemsSource="{Binding KindOptions}"
                              SelectedItem="{Binding SelectedKind, Mode=TwoWay}" />
                </StackPanel>
            </Grid>

            <!-- List + (optional) Detail preview pane, with the rename bar overlaid -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- History list -->
                    <ListBox Grid.Column="0"
                             Name="ItemsList"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding Selected, Mode=TwoWay}"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ClipRow">
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                                    <Panel Grid.Column="0" Width="24" Margin="0,0,10,0" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding KindGlyph}" FontSize="15"
                                                   IsVisible="{Binding ShowGlyph}" Opacity="0.85" />
                                        <Image Source="{Binding Thumbnail}" Width="24" Height="24"
                                               IsVisible="{Binding HasThumbnail}" Stretch="UniformToFill" />
                                    </Panel>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Preview}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2" TextWrapping="Wrap"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding Meta}"
                                                   FontSize="11" Opacity="0.55" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding PinGlyph}"
                                               FontSize="13" VerticalAlignment="Top" Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Detail preview pane (collapses to 0 width in Compact mode) -->
                    <Border Grid.Column="1" Width="340" Margin="12,0,0,0"
                            IsVisible="{Binding IsDetail}"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="8" Padding="14">
                        <Grid RowDefinitions="Auto,*">
                            <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,10">
                                <TextBlock Text="{Binding Selected.Item.Kind}"
                                           FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="{Binding Selected.Meta}"
                                           FontSize="11" Opacity="0.6" />
                            </StackPanel>
                            <ScrollViewer Grid.Row="1">
                                <Panel>
                                    <Image Source="{Binding PreviewImage}"
                                           IsVisible="{Binding PreviewHasImage}"
                                           Stretch="Uniform" StretchDirection="DownOnly"
                                           HorizontalAlignment="Left" VerticalAlignment="Top" />
                                    <TextBlock Text="{Binding Selected.FullText}"
                                               IsVisible="{Binding PreviewHasText}"
                                               TextWrapping="Wrap"
                                               FontFamily="Cascadia Code,Consolas,monospace"
                                               FontSize="12.5" />
                                </Panel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Rename bar (F2) — overlays the top of the list area -->
                <Border ZIndex="10" VerticalAlignment="Top"
                        IsVisible="{Binding IsRenaming}"
                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                        BorderBrush="{DynamicResource SystemAccentColor}" BorderThickness="1"
                        CornerRadius="8" Padding="10,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Rename:" VerticalAlignment="Center" Opacity="0.7" />
                        <TextBox Name="RenameBox" Width="380"
                                 Text="{Binding RenameText, Mode=TwoWay}"
                                 PlaceholderText="alias (empty to clear)" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status bar -->
            <TextBlock Grid.Row="3" Margin="2,10,2,0"
                       Text="{Binding Status}"
                       FontSize="11" Opacity="0.5" />
        </Grid>
    </Border>
</Window>
