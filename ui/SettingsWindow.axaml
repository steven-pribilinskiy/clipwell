<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Clipwell.Ui.SettingsWindow"
        Title="Clipwell Settings"
        Width="440" Height="640"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="24">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />

            <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto,Auto" Margin="0,14,0,0">
                <TextBlock Grid.Column="0" Name="StatusText" FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                <Button Grid.Column="1" Name="CloseButton" Content="Close" Padding="16,6" Margin="0,0,10,0" />
                <Button Grid.Column="2" Name="SaveButton" Content="Save" Padding="16,6"
                        Background="{DynamicResource SystemAccentColor}" />
            </Grid>

            <ScrollViewer>
                <StackPanel Spacing="18">

                    <StackPanel Spacing="6">
                        <TextBlock Text="Appearance" FontWeight="Medium" />
                        <ComboBox Name="ThemeBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem>System</ComboBoxItem>
                            <ComboBoxItem>Light</ComboBoxItem>
                            <ComboBoxItem>Dark</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Default view" FontWeight="Medium" />
                        <ComboBox Name="ViewBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem>Compact</ComboBoxItem>
                            <ComboBoxItem>Detail</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Default grouping" FontWeight="Medium" />
                        <ComboBox Name="GroupBox" HorizontalAlignment="Stretch">
                            <ComboBoxItem>No grouping</ComboBoxItem>
                            <ComboBoxItem>By date</ComboBoxItem>
                            <ComboBoxItem>By source</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Row metadata" FontWeight="Medium" />
                        <CheckBox Name="ShowSourceBox" Content="Show source app" />
                        <CheckBox Name="ShowTimeBox" Content="Show time" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="History retention" FontWeight="Medium" />
                        <TextBlock Text="How long to keep clipboard history before it's swept."
                                   FontSize="12" Opacity="0.6" />
                        <ComboBox Name="RetentionBox" HorizontalAlignment="Stretch" SelectedIndex="1">
                            <ComboBoxItem>7 days</ComboBoxItem>
                            <ComboBoxItem>30 days</ComboBoxItem>
                            <ComboBoxItem>90 days</ComboBoxItem>
                            <ComboBoxItem>Forever</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Picker position" FontWeight="Medium" />
                        <CheckBox Name="OpenAtCursorBox" Content="Open at the mouse cursor" />
                        <TextBlock Text="Otherwise the picker opens centered on the screen."
                                   FontSize="12" Opacity="0.6" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Global hotkey" FontWeight="Medium" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                    CornerRadius="6" Padding="10,6" MinWidth="140" VerticalAlignment="Center">
                                <TextBlock Name="HotkeyText" Text="Alt+Shift+V"
                                           FontFamily="Cascadia Code,Consolas,monospace" />
                            </Border>
                            <Button Name="RecordButton" Content="Change…" Padding="12,6" />
                        </StackPanel>
                        <TextBlock Text="Click Change, then press a combo (e.g. Ctrl+Shift+V). Requires a modifier."
                                   FontSize="12" Opacity="0.6" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
